# Mot de passe pour accéder à /admin
ADMIN_PASSWORD=changez-moi

# Clé secrète pour signer les sessions (chaîne aléatoire longue)
AUTH_SECRET=generez-une-chaine-aleatoire-ici

# Vercel Blob — rempli automatiquement sur Vercel
# En dev local, lancez `vercel env pull` pour récupérer ce token
BLOB_READ_WRITE_TOKEN=
