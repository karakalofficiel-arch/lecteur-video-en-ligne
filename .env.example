# ── Admin ──────────────────────────────────────────────────────────
# Mot de passe initial (modifiable depuis /admin après la première connexion)
ADMIN_PASSWORD=changez-moi

# Clé secrète pour signer les sessions (chaîne aléatoire 64 hex)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=generez-une-chaine-aleatoire-ici

# ── Supabase ───────────────────────────────────────────────────────
# Disponibles dans : supabase.com → votre projet → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # secret, ne jamais exposer côté client
